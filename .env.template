# Anthropic API key (Claude 4.x). Get one from https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Frontend → backend URL. Local dev points at uvicorn; production is the Render service.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend self-reference (used for CORS allowlist if you add multiple frontends).
BACKEND_URL=http://localhost:8000

# Comma-separated list of frontend origins allowed to call the backend.
# Local dev: http://localhost:3000
# Production (Vercel): set to your deployed Vercel URL, e.g. https://auditdoc.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Katzilla government data verification (disabled by default)
KATZILLA_ENABLED=false
KATZILLA_API_KEY=
KATZILLA_API_BASE=https://api.katzilla.dev
KATZILLA_TIMEOUT=5
